{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Desktop permissions for session recovery and signed application updates",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/XVibeCoding/codex-session-hub"
        },
        {
          "url": "https://github.com/XVibeCoding/codex-session-hub/releases"
        }
      ]
    }
  ]
}
